local function hookTools(char)
    for _, tool in pairs(char:GetChildren()) do
        if tool:IsA("Tool") then tool.Activated:Connect(function() lastPunchTime = tick() end) end
    end
    char.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then child.Activated:Connect(function() lastPunchTime = tick() end) end
    end)
end
local damageCheckConnection = RunService.Heartbeat:Connect(function()
    if not damageCounterEnabled then return end
    local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    for _, plr in pairs(Players:GetPlayers()) do
        if plr == player then continue end
        local char = plr.Character
        if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then continue end
        local currentHealth = hum.Health
        local prev = previousHealth[plr] or currentHealth
        local dmg = prev - currentHealth
        if dmg > 0.1 and (tick() - lastPunchTime < 3) then
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                local dist = (root.Position - myRoot.Position).Magnitude
                if dist < 50 then
                    createDamagePopup(dmg, root)
                end
            end
        end
        previousHealth[plr] = currentHealth
    end
end)
