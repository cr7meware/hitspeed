local function makeButton(parent, text, pos)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 240, 0, 26)
    btn.Position = UDim2.new(0.5, 0, pos.Y.Scale, pos.Y.Offset)
