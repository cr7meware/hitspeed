    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    btn.Parent = parent
    btn.MouseEnter:Connect(function() btn.BackgroundColor3 = Color3.fromRGB(55, 0, 0) end)
    btn.MouseLeave:Connect(function() btn.BackgroundColor3 = Color3.fromRGB(30, 30, 35) end)
