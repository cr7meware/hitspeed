local function getRemote()
    local char = player.Character or player.CharacterAdded:Wait()
    for i = 1, 20 do
        local core = char:FindFirstChild("Core")
        if core then
            local comm = core:FindFirstChild("Communicate")
            if comm and comm:FindFirstChildOfClass("RemoteEvent") then
                return comm:FindFirstChildOfClass("RemoteEvent")
            end
        end
        task.wait()
    end
    return nil
end

local function startAutoweave()
    if autoweaveActive then return end
    autoweaveActive = true
    autoweaveTask = task.spawn(function()
        while autoweaveActive do
            local remote = getRemote()
            if remote then
                remote:FireServer("Weave", nil, true)
                task.wait(HoldDuration)
                if not autoweaveActive then break end
                remote:FireServer("Weave", nil, false)
                task.wait(ReweaveDelay)  -- ← now actually works
            else
                task.wait()
            end
        end
    end)
end

local function stopAutoweave()
    autoweaveActive = false
    if autoweaveTask then task.cancel(autoweaveTask) end
    autoweaveTask = nil
    local remote = getRemote()
    if remote then remote:FireServer("Weave", nil, false) end
end

